{
  "version": "0.1.0",
  "stack": "java-spring",
  "extends": "../rules-config.json",
  "rulesFile": ".ai-rules.md",
  "i18n": {
    "defaultLocale": "zh-CN",
    "supportedLocales": [
      "zh-CN",
      "en"
    ],
    "localeDir": "../../i18n"
  },
  "enabledRuleIds": [
    "JAVA-ARCH-101",
    "JAVA-ARCH-102",
    "JAVA-SEC-202",
    "JAVA-API-301",
    "JAVA-DATA-401"
  ],
  "severityThreshold": "WARN",
  "scopes": [
    "architecture",
    "security",
    "api",
    "data"
  ],
  "pathAliases": {
    "@controller": "src/main/java/**/controller",
    "@service": "src/main/java/**/service",
    "@repository": "src/main/java/**/repository",
    "@dto": "src/main/java/**/dto"
  },
  "detectOptions": {
    "include": [
      "src/main/java/**/*.java",
      "src/test/java/**/*.java",
      "src/main/resources/application*.yml",
      "pom.xml",
      "build.gradle",
      "build.gradle.kts"
    ],
    "exclude": [
      "target/**",
      "build/**"
    ]
  },
  "prompt": {
    "style": "strict",
    "includeContextAssets": true,
    "promptTemplateKeys": {
      "auditSystem": "prompt.audit.system",
      "auditUser": "prompt.audit.user",
      "repairSystem": "prompt.repair.system",
      "repairUser": "prompt.repair.user"
    }
  }
}
