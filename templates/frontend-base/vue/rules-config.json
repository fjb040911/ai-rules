{
  "version": "0.1.0",
  "stack": "vue-ts",
  "extends": "../rules-config.json",
  "rulesFile": ".ai-rules.md",
  "i18n": {
    "defaultLocale": "zh-CN",
    "supportedLocales": [
      "zh-CN",
      "en"
    ],
    "localeDir": "../../i18n"
  },
  "enabledRuleIds": [
    "VUE-301",
    "VUE-302",
    "VUE-303",
    "VUE-304",
    "VUE-305"
  ],
  "scopes": [
    "vue"
  ],
  "detectOptions": {
    "include": [
      "src/**/*.{ts,tsx,vue}"
    ]
  },
  "prompt": {
    "style": "strict",
    "includeContextAssets": true,
    "promptTemplateKeys": {
      "auditSystem": "prompt.audit.system",
      "auditUser": "prompt.audit.user",
      "repairSystem": "prompt.repair.system",
      "repairUser": "prompt.repair.user"
    }
  }
}
